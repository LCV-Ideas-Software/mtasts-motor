{
  "name": "mtasts-motor",
  "version": "2.0.12",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker that serves dynamic MTA-STS policies for mta-sts.* subdomains, sourcing active policy text from a D1 binding.",
  "license": "AGPL-3.0-or-later",
  "author": "LCV Ideas & Software",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LCV-Ideas-Software/mtasts-motor.git"
  },
  "homepage": "https://github.com/LCV-Ideas-Software/mtasts-motor#readme",
  "bugs": {
    "url": "https://github.com/LCV-Ideas-Software/mtasts-motor/issues"
  },
  "scripts": {
    "format": "biome format --write src",
    "lint": "biome check src",
    "biome": "biome check .",
    "biome:write": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "format:public": "prettier --write \"**/index.html\"",
    "format:public:check": "prettier --check \"**/index.html\""
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@cloudflare/workers-types": "^4.20260601.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.96.0",
    "prettier": "^3.8.3"
  },
  "overrides": {
    "ws": "8.20.1"
  }
}
